# Local dev (SQLite) — omit DATABASE_URL
# SQLITE_PATH=data/wwtd.db

# Production (Supabase Postgres) — paste from Supabase → Connect → ORM / URI
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

JWT_SECRET=change-me-in-production
EXPOSE_DEV_OTP=true

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8000
